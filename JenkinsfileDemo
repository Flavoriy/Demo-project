pipeline {
    agent {
        label 'agent'
    }

    environment {
        CI = 'true'
        NEXT_TELEMETRY_DISABLED = '1'
        REGISTRY = 'ghcr.io'
        IMAGE_REPOSITORY = 'ghcr.io/flavoriy/tikto'
        DOCKERFILE = 'Dockerfile'
        MY_DOCKER_CONTEXT = '.' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Image Tag') {
            steps {
                script {
                    String branchName = env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'local'
                    String commit = env.GIT_COMMIT ?: sh(script: 'git rev-parse --short=12 HEAD', returnStdout: true).trim()
                    String rawTag = "${branchName}-${commit.take(12)}-${env.BUILD_NUMBER ?: '0'}"

                    // Ép toàn bộ định dạng chuỗi tag về chữ thường (lowercase) để Docker an tâm build
                    env.IMAGE_TAG = rawTag
                        .replaceFirst(/^origin\//, '')
                        .replaceAll(/[^A-Za-z0-9_.-]/, '-')
                        .take(128)
                        .toLowerCase()
                        
                    env.IMAGE_REF = "${env.IMAGE_REPOSITORY}:${env.IMAGE_TAG}"

                    echo "Docker image target ref: ${env.IMAGE_REF}"
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo 'Building Docker image on Jenkins agent...'
                withCredentials([file(credentialsId: 'tikto', variable: 'SECRET_ENV')]) {
                    sh '''
                        set -e
                        
                        # Sử dụng sed để loại bỏ comment (#) và các dòng trống trước khi export
                        export $(sed 's/#.*//g' "$SECRET_ENV" | xargs)
                        
                        # Tiến hành build và truyền biến vào
                        docker build \
                          --build-arg DATABASE_URL="$DATABASE_URL" \
                          -f "$DOCKERFILE" \
                          -t "$IMAGE_REF" \
                          "$MY_DOCKER_CONTEXT"
                    '''
                }
            }
        }

        stage('Docker Push GHCR') {
            steps {
                echo 'Pushing Docker image to GHCR...'
                // Sửa đổi từ loại 'usernamePassword' sang 'string' để nhận diện đúng loại Secret text 'ghcr-token'
                withCredentials([string(credentialsId: 'ghcr-token', variable: 'REGISTRY_TOKEN')]) {
                    sh '''
                        set -e
                        set +x
                        # Hệ thống sử dụng trực tiếp token kết hợp với tên tài khoản của bạn để login
                        echo "$REGISTRY_TOKEN" | docker login "$REGISTRY" -u "flavoriy" --password-stdin
                        set -x
                        
                        docker push "$IMAGE_REF"
                        docker logout "$REGISTRY"
                    '''
                }
            }
        }
    }
}